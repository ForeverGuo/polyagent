# ── LLM 配置（必填）─────────────────────────────────────────────────────────
API_KEY=your-api-key-here
API_BASE=https://api.siliconflow.cn/v1
MODEL=Pro/zai-org/GLM-4.7

# ── 其他服务商示例（按需替换上方三项）────────────────────────────────────────
# OpenAI
# API_KEY=sk-...
# API_BASE=https://api.openai.com/v1
MODEL=gpt-4o

# Azure OpenAI
# API_KEY=...
# API_BASE=https://<your-resource>.openai.azure.com/
# MODEL=gpt-4o

# Ollama（本地）
# API_KEY=ollama
# API_BASE=http://localhost:11434/v1
# MODEL=llama3.2

# ── 工具 API Keys（可选）────────────────────────────────────────────────────
# Tavily 搜索，chat 链路联网功能需要，免费申请：https://tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# ── API 测试配置（可选）─────────────────────────────────────────────────────
# 外部 API 集成测试的认证令牌
# 从 https://api-dev.welltivity.cn 获取有效 token
TOKEN=your-api-token-here

# 外部 API 基础地址（默认：https://api-dev.welltivity.cn/api/admin）
BASE_URL=https://api-dev.welltivity.cn/api/admin
