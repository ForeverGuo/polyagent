# ── LLM 配置（必填）─────────────────────────────────────────────────────────
API_KEY=your-api-key-here
API_BASE=https://api.siliconflow.cn/v1
MODEL=Pro/zai-org/GLM-4.7

# ── 其他服务商示例（按需替换上方三项）────────────────────────────────────────
# OpenAI
# API_KEY=sk-...
# API_BASE=https://api.openai.com/v1
# MODEL=gpt-4o

# Azure OpenAI
# API_KEY=...
# API_BASE=https://<your-resource>.openai.azure.com/
# MODEL=gpt-4o

# Ollama（本地）
# API_KEY=ollama
# API_BASE=http://localhost:11434/v1
# MODEL=llama3.2

# ── 工具 API Keys（可选）────────────────────────────────────────────────────
# Tavily 搜索，chat 链路联网功能需要，免费申请：https://tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# ── 产物输出目录（可选）─────────────────────────────────────────────────────
# 生成的代码、测试文件、报告、截图等的输出根目录，默认 "user"
# 设为 "." 可直接输出到当前工作目录
# POLYAGENT_OUTPUT_DIR=polyagent_output

# ── API 测试配置（可选）─────────────────────────────────────────────────────
# swagger 链路运行测试时使用，也可在交互模式中实时输入
TOKEN=your-api-token-here
BASE_URL=http://localhost:8000
