# ── LLM 配置（必填）─────────────────────────────────────────────────────────
API_KEY=your-api-key-here
API_BASE=https://api.siliconflow.cn/v1
MODEL=Pro/zai-org/GLM-4.7

# ── 其他服务商示例（按需替换上方三项）────────────────────────────────────────
# OpenAI
# API_KEY=sk-...
# API_BASE=https://api.openai.com/v1
# MODEL=gpt-4o

# Azure OpenAI
# API_KEY=...
# API_BASE=https://<your-resource>.openai.azure.com/
# MODEL=gpt-4o

# Ollama（本地）
# API_KEY=ollama
# API_BASE=http://localhost:11434/v1
# MODEL=llama3.2

# ── 工具 API Keys（可选）────────────────────────────────────────────────────
# Tavily 搜索，chat 链路联网功能需要，免费申请：https://tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# ── 产物输出目录（可选）─────────────────────────────────────────────────────
# 生成的代码、测试文件、报告、截图等的输出根目录，默认 "user"
# 设为 "." 可直接输出到当前工作目录
# POLYAGENT_OUTPUT_DIR=polyagent_output

# ── SSL 证书（企业网络 / 代理环境）──────────────────────────────────────────
# 如果网络使用自签名证书，设为 false 跳过验证（不推荐生产环境）
# SSL_VERIFY=false
# 或指定企业 CA 证书路径
# SSL_CA_BUNDLE=C:\certs\company-ca.pem

# ── API 测试配置（可选）─────────────────────────────────────────────────────
# swagger 链路运行测试时使用，也可在交互模式中实时输入
TOKEN=your-api-token-here
BASE_URL=http://localhost:8000

# ── App 测试配置（可选，app 链路使用）────────────────────────────────────────
# 使用前需先启动 Appium Server：
#   npm install -g appium
#   appium driver install uiautomator2
#   appium --port 4723
# 并确保 adb devices 能看到设备
APPIUM_SERVER=http://localhost:4723
APP_PLATFORM=Android
APP_DEVICE_NAME=emulator-5554
# 默认启动的 App 包名与 Activity（任务里也可显式指定）
APP_PACKAGE=
APP_ACTIVITY=
